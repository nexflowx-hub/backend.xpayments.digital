datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

enum TierLevel {
  TIER_C_STANDARD
  TIER_B_PRO
  TIER_A_PREMIUM
  TIER_D_RISK
  TIER_VIP
}

enum LedgerStatus {
  INCOMING
  PENDING
  RESERVE
  AVAILABLE
  CLEARED
  AUDIT
  BLOCKED
}

model Merchant {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String    @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  password           String    @db.VarChar(255)
  tier               TierLevel @default(TIER_C_STANDARD)
  payoutWalletUSDT   String?   @db.VarChar(255)
  customFeePercent   Decimal?  @db.Decimal(5,2)
  hasRiskReserve     Boolean   @default(false)
  reservePercent     Decimal   @default(0.00) @db.Decimal(5,2)
  reserveDays        Int       @default(0)
  status             String    @default("ACTIVE") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz

  transactions       Transaction[]
  ledgers            Ledger[]
  apiKeys            ApiKey[]
  payoutRequests     PayoutRequest[]
  stores             Store[]
  gatewayVaults      GatewayVault[]
  customers          Customer[] 
  supportTickets     SupportTicket[]
  tierRequests       TierUpgradeRequest[]
}

model Store {
  id               String    @id @default(uuid()) @db.Uuid
  merchantId       String    @db.Uuid
  merchant         Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName     String?   @db.VarChar(255)
  name             String    @db.VarChar(255)
  logoUrl          String?   @db.VarChar(255)
  primaryColor     String?   @default("#111111") @db.VarChar(50)
  accentColor      String?   @default("#10b981") @db.VarChar(50)
  successUrl       String?   @db.VarChar(255) 
  supportEmail     String?   @db.VarChar(255) 
  webhookUrl       String?   @db.VarChar(255)
  webhookSecret    String?   @db.VarChar(255)
  checkoutConfig   Json?     
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now()) @db.Timestamptz

  transactions     Transaction[]
  paymentLinks     PaymentLink[]
}

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  merchantId   String   @db.Uuid
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName String?  @db.VarChar(255)
  email        String   @db.VarChar(255)
  name         String?  @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  taxId        String?  @db.VarChar(50) 
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz
  transactions Transaction[]
  @@unique([merchantId, email]) 
}

model GatewayVault {
  id               String    @id @default(uuid()) @db.Uuid
  merchantId       String?   @db.Uuid
  merchant         Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName     String?   @db.VarChar(255) 
  providerId       String    @unique @db.VarChar(100) 
  publicName       String?   @db.VarChar(100) 
  authConfig       String    @db.Text
  webhookConfig    String?   @db.Text
  metadata         String?   @db.Text
  status           String    @default("ACTIVE") @db.VarChar(50)
  lifecycleStatus  String    @default("OPERATIONAL") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @db.Timestamptz
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  merchantId      String   @db.Uuid
  storeId         String?  @db.Uuid
  customerId      String?  @db.Uuid
  merchant        Merchant  @relation(fields: [merchantId], references: [id])
  store           Store?    @relation(fields: [storeId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  merchantName    String?  @db.VarChar(255) 
  storeName       String?  @db.VarChar(255) 
  customerEmail   String?  @db.VarChar(255) 
  amountFiat      Decimal  @db.Decimal(15,2)
  currency        String   @db.VarChar(10)
  exchangeRate    Decimal  @db.Decimal(10,6)
  amountUSDT      Decimal  @db.Decimal(15,2)
  feeUSDT         Decimal  @db.Decimal(15,2)
  netAmountUSDT   Decimal  @db.Decimal(15,2)
  providerUsed    String?  @db.VarChar(100)
  providerTxId    String?  @db.VarChar(255)
  status          String   @default("PENDING_GATEWAY") @db.VarChar(50)
  metadata        Json?
  createdAt       DateTime @default(now()) @db.Timestamptz
  ledgers         Ledger[]
}

model Ledger {
  id              String       @id @default(uuid()) @db.Uuid
  merchantId      String       @db.Uuid
  transactionId   String       @db.Uuid
  merchant        Merchant     @relation(fields: [merchantId], references: [id])
  transaction     Transaction  @relation(fields: [transactionId], references: [id])
  merchantName    String?      @db.VarChar(255)
  type            String       @db.VarChar(50)
  amountUSDT      Decimal      @db.Decimal(15,2)
  status          LedgerStatus @default(INCOMING)
  incomingAt      DateTime     @default(now()) @db.Timestamptz
  pendingAt       DateTime?    @db.Timestamptz
  availableAt     DateTime?    @db.Timestamptz
  clearedAt       DateTime?    @db.Timestamptz
  notes           String?      @db.Text
}

model PaymentLink {
  id              String    @id @default(uuid()) @db.Uuid
  storeId         String    @db.Uuid
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeName       String?   @db.VarChar(255) 
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  imageUrl        String?   @db.VarChar(255)
  amountFiat      Decimal   @db.Decimal(15,2)
  currency        String    @default("EUR") @db.VarChar(10)
  urlCode         String    @unique @db.VarChar(100)
  isReusable      Boolean   @default(true) 
  expiresAt       DateTime? @db.Timestamptz 
  requireShipping Boolean   @default(false)
  requireTaxId    Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz
}

model ApiKey {
  id           String   @id @default(uuid()) @db.Uuid
  merchantId   String   @db.Uuid
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName String?  @db.VarChar(255) 
  publicKey    String   @unique @db.VarChar(255)
  secretKey    String   @unique @db.VarChar(255)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
}

model PayoutRequest {
  id                String    @id @default(uuid()) @db.Uuid
  merchantId        String    @db.Uuid
  merchant          Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName      String?   @db.VarChar(255)
  amountUSDT        Decimal   @db.Decimal(15,2)
  requestedCurrency String    @default("USDT") @db.VarChar(10)
  destinationInfo   String    @db.Text
  status            String    @default("PENDING") @db.VarChar(50)
  txHash            String?   @db.VarChar(255)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  processedAt       DateTime? @db.Timestamptz
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255) 
  role         String   @default("SUPER_ADMIN") @db.VarChar(50) 
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz
}

model SupportTicket {
  id           String   @id @default(uuid()) @db.Uuid
  merchantId   String   @db.Uuid
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName String?  @db.VarChar(255) 
  subject      String   @db.VarChar(255)
  message      String   @db.Text
  status       String   @default("OPEN") @db.VarChar(50)
  response     String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz
}

model TierUpgradeRequest {
  id            String    @id @default(uuid()) @db.Uuid
  merchantId    String    @db.Uuid
  merchant      Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  merchantName  String?   @db.VarChar(255) 
  requestedTier TierLevel
  reason        String?   @db.Text
  status        String    @default("PENDING") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @db.Timestamptz
  resolvedAt    DateTime? @db.Timestamptz
}
